---
import '../styles/archive.css';
const { title = 'Finch Archive', hideHeader = false } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
{!hideHeader && (
      <header>
        <a href="/">Finch Archive</a>
        <nav>
          <a href="/logs/">Logs</a>
          <a href="/field-notes/">Field Notes</a>
          <a href="/timeline/">Timeline</a>
        </nav>
      </header>
    )}

    <slot />
  </body>
</html>
