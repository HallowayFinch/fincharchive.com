---
import { archiveOfficeDesk } from '../archive/locations';
import type { LocationSceneData } from '../archive/models/scene';
import PresenceLayer from './PresenceLayer.astro';

type Props = {
  scene?: LocationSceneData;
};

const { scene = archiveOfficeDesk } = Astro.props;
---

<section class="location-scene" aria-label={scene.name}>
  <div
    class="location-scene__surface"
    style={`background-image:
      url(${scene.location.assets.background}),
      radial-gradient(circle at 34% 26%, rgba(214, 154, 83, 0.24), transparent 30%),
      linear-gradient(135deg, #24170f, #090706 70%);`}
  >
    <PresenceLayer systems={scene.location.presence} />

    {scene.ambient?.map((object) => {
      const objectImage = object.image ? `url(${object.image})` : 'none';

      return (
        <span
          class={`location-scene__ambient location-scene__ambient--${object.id}`}
          aria-hidden="true"
          style={`
            left:${object.x}%;
            top:${object.y}%;
            width:${object.width}%;
            height:${object.height}%;
            --object-image: ${objectImage};
          `}
        />
      );
    })}

    {scene.materials.map((object) => {
      const objectName = object.name ?? object.label;
      const objectStatus = object.status ?? 'INDEXED';
      const objectImage = object.image ? `url(${object.image})` : 'none';
      const objectHref = object.href ?? '#';
      const accessibleLabel = [objectName, object.assetId, `Status: ${objectStatus}`]
        .filter(Boolean)
        .join('. ');

      return (
        <a
          class={`location-scene__object location-scene__object--${object.id}`}
          href={objectHref}
          aria-label={accessibleLabel}
          style={`
            left:${object.x}%;
            top:${object.y}%;
            width:${object.width}%;
            height:${object.height}%;
            --object-image: ${objectImage};
          `}
        >
          <span class="location-scene__object-plate">
            <span class="location-scene__object-name">{objectName}</span>
            {object.assetId && <span class="location-scene__object-id">{object.assetId}</span>}
          </span>
          <span class="location-scene__hover-label" aria-hidden="true">
            <span>{objectName}</span>
            {object.assetId && <span>{object.assetId}</span>}
            <span>STATUS: {objectStatus}</span>
          </span>
        </a>
      );
    })}
  </div>
</section>
