---
import { marked } from 'marked';
import ArchiveLayout from '../../layouts/ArchiveLayout.astro';
import { getLog, getLogSlugs } from '../../lib/archive';

export async function getStaticPaths() {
  const slugs = await getLogSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;
const log = await getLog(slug!);
const html = marked.parse(log.body);
---

<ArchiveLayout title={`${log.title} · Finch Archive`}>
  <main>
    <p><a href="/logs/">Logs</a></p>
    <h1>{log.title}</h1>
    <time datetime={log.date}>{log.date}</time>
    <article set:html={html} />
  </main>
</ArchiveLayout>
